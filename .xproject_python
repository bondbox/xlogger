name = "xlogger"
home = "https://github.com/bondbox/xlogger/"
description = "Logging module"
keywords = [
    "colorama",
    "colorlog",
    "logger",
    "logging",
]
version = "0.3"

[authors.zoumingzhe]
name = "Mingzhe Zou"
email = "zoumingzhe@outlook.com"

[packages.xkits-logger]
requires_python = ">=3.8"
authors = [
    "zoumingzhe",
]
keywords = []
requirements = [
    "colorama",
    "colorlog",
]
build_backend = "hatchling"
max_complexity = 10
max_line_length = 127

[packages.xkits-logger.modules.xkits-logger]
base = "xkits_logger"
exclude = [
    "unittest",
]
omitted = [
    "unittest/*",
    "attribute.py",
]

[packages.xkits-logger.modules.xkits-logger.scripts]

[packages.xkits-logger.modules.xkits-logger.templates]
"__init__.py" = false
"attribute.py" = true
